# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# ── Model ──────────────────────────────────────────────────────────────────
# Provider is auto-detected from the model name prefix:
#   claude-*          → Anthropic API  (needs ANTHROPIC_API_KEY)
#   gpt-* / o1* / o3* → OpenAI API    (needs OPENAI_API_KEY)
MODEL=claude-opus-4-8
#MODEL=gpt-4o

# ── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── IBM Cloud Logs ───────────────────────────────────────────────────────────
# Obtain from: IBM Cloud console → your Logs instance → Endpoints
# Use the API endpoint (api.*), NOT the ingress endpoint.
# The code auto-converts .ingress. → .api. if you paste the ingress host.
IBM_CLOUD_API_KEY=
IBM_LOGS_ENDPOINT=https://<guid>.api.us-south.logs.cloud.ibm.com

# ── Grafana (optional — only needed for metrics Path C, requires VPN) ────────
# GRAFANA_TOKEN=glsa_...
