# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# ── Model provider ──────────────────────────────────────────────────────────
# MODEL_PROVIDER selects the backend.  If not set, it is inferred from MODEL:
#   gpt-* / o1* / o3* / o4*  → openai
#   claude-*                  → anthropic
#   gemini-*                  → gemini
#   anything else             → ollama
#
# Uncomment exactly ONE block below.

# ── OpenAI ──────────────────────────────────────────────────────────────────
MODEL_PROVIDER=openai
MODEL=gpt-5.5
OPENAI_API_KEY=sk-...

# ── Anthropic ───────────────────────────────────────────────────────────────
# MODEL_PROVIDER=anthropic
# MODEL=claude-opus-4-8
# ANTHROPIC_API_KEY=sk-ant-...

# ── Gemini ───────────────────────────────────────────────────────────────────
# MODEL_PROVIDER=gemini
# MODEL=gemini-2.5-pro
# GOOGLE_API_KEY=AIza...
# (or GEMINI_API_KEY=... if you prefer)

# ── Ollama local ─────────────────────────────────────────────────────────────
# MODEL_PROVIDER=ollama
# MODEL=gemma3:12b
# OLLAMA_BASE_URL=http://localhost:11434

# ── OpenAI-compatible (vLLM / LM Studio / NVIDIA NIM / Groq / etc.) ─────────
# MODEL_PROVIDER=openai-compatible
# MODEL=<model-id>
# OPENAI_COMPATIBLE_BASE_URL=https://your-endpoint.example.com
# OPENAI_COMPATIBLE_API_KEY=<key or leave blank for local servers>

# ── IBM Cloud Logs ───────────────────────────────────────────────────────────
# Obtain from: IBM Cloud console → your Logs instance → Endpoints
# The code auto-converts .ingress. → .api. if you paste the ingress host.
IBM_CLOUD_API_KEY=
IBM_LOGS_ENDPOINT=https://<guid>.api.us-south.logs.cloud.ibm.com

# ── Grafana (optional — only needed for metrics Path C, requires VPN) ────────
# GRAFANA_TOKEN=glsa_...
